{
  "name": "leapfrog-hr-management",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1 --port 3000",
    "build": "prisma generate && next build",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "tsx src/test/run-tests.ts",
    "test:phase3": "tsx src/test/run-tests.ts",
    "test:phase4": "tsx src/test/run-tests.ts",
    "test:phase45": "tsx src/test/run-tests.ts",
    "test:phase5": "tsx src/test/run-tests.ts",
    "test:payroll-calculation": "tsx src/test/run-tests.ts",
    "test:phase2-workflows": "tsx src/test/phase2-workflow-smoke.ts",
    "test:watch": "tsx --watch src/test/run-tests.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "tsx prisma/seed.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "overrides": {
    "postcss": "^8.5.10",
    "uuid": "^11.1.1"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "exceljs": "^4.4.0",
    "jose": "^5.9.6",
    "lucide-react": "^0.468.0",
    "next": "^15.1.0",
    "papaparse": "^5.4.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.2",
    "@types/papaparse": "^5.3.15",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
