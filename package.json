{
  "name": "leapfrog-hr-management",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1 --port 3000",
    "build": "prisma generate && next build",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "tsx src/test/phase1-tests.ts && tsx src/test/phase2a-tests.ts && tsx src/test/phase2b-tests.ts && tsx src/test/phase3-tests.ts && tsx src/test/phase3_5-tests.ts && tsx src/test/phase4a-tests.ts && tsx src/test/phase4b-tests.ts && tsx src/test/phase4c1-tests.ts && tsx src/test/phase4c2-tests.ts && tsx src/test/phase5a-tests.ts && tsx src/test/phase5b-tests.ts",
    "test:phase1": "tsx src/test/phase1-tests.ts",
    "test:phase2a": "tsx src/test/phase2a-tests.ts",
    "test:phase2b": "tsx src/test/phase2b-tests.ts",
    "test:phase3": "tsx src/test/phase3-tests.ts",
    "test:phase3_5": "tsx src/test/phase3_5-tests.ts",
    "test:phase4a": "tsx src/test/phase4a-tests.ts",
    "test:phase4b": "tsx src/test/phase4b-tests.ts",
    "test:phase4c1": "tsx src/test/phase4c1-tests.ts",
    "test:phase4c2": "tsx src/test/phase4c2-tests.ts",
    "test:phase4c2-e2e": "tsx src/test/phase4c2-e2e-tests.ts",
    "test:phase5a": "tsx src/test/phase5a-tests.ts",
    "test:phase5a-e2e": "tsx src/test/run-phase5a-e2e.ts",
    "verify:phase5a": "tsx src/test/phase5a-tests.ts && tsx src/test/run-phase5a-e2e.ts",
    "test:phase5b": "tsx src/test/phase5b-tests.ts",
    "test:phase5b-e2e": "tsx src/test/run-phase5b-e2e.ts",
    "test:mvp": "tsx src/test/mvp-employee-tests.ts && tsx src/test/mvp-payroll-tests.ts",
    "test:mvp-e2e": "tsx src/test/run-mvp-e2e.ts",
    "verify:mvp": "npm run prisma:generate && npm run typecheck && npm run lint && npm run build && npm run test:mvp && npm run test:mvp-e2e",
    "verify:phase5b": "npm run prisma:generate && npm run typecheck && npm run lint && npm run build && npm run verify:phase5a && npm run test:phase5b",
    "test:kpi-assignment": "tsx src/test/run-kpi-assignment-e2e.ts",
    "test:kpi-assignment:http": "tsx src/test/kpi-assignment-tests.ts",
    "test:ui-e2e": "playwright test",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "tsx prisma/seed.ts",
    "prisma:seed:ci": "tsx prisma/seed-ci.ts",
    "prisma:seed:master": "tsx prisma/seed.ts",
    "prisma:seed:demo": "tsx prisma/seed-phase5a-demo.ts",
    "seed:all": "tsx prisma/seed.ts && tsx prisma/seed-phase5a-demo.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "overrides": {
    "postcss": "^8.5.10",
    "uuid": "^11.1.1"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "decimal.js": "^10.6.0",
    "exceljs": "^4.4.0",
    "jose": "^5.9.6",
    "lucide-react": "^0.468.0",
    "next": "^15.1.0",
    "papaparse": "^5.4.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.2",
    "@types/papaparse": "^5.3.15",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
