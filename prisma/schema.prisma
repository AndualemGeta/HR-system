enum PaymentMethod {
  BANK
  MPESA
  MANUAL
  HOLD
}

enum PayrollOutputPackageStatus {
  FINALIZED
  REVIEWED
  APPROVED
  CANCELLED
}

enum PayrollPaymentBatchStatus {
  DRAFT
  GENERATED
  REVIEWED
  APPROVED
  RELEASED
  PARTIALLY_PAID
  PAID
  FAILED
  CANCELLED
}

enum PayrollPaymentInstructionStatus {
  PENDING
  PAID
  FAILED
  RETURNED
  HELD
}

enum PayrollStatutoryReportType {
  PAYE
  EMPLOYEE_PENSION
  EMPLOYER_PENSION
  COMBINED_PENSION
}

enum PayrollStatutoryReportStatus {
  DRAFT
  REVIEWED
  APPROVED
  FILED
}

enum ExportFormat {
  CSV
  XLSX
}

model PayrollOutputPackage {
  id                        String                       @id @default(uuid())
  payrollPeriodId           String
  payrollPreparationBatchId String                       @unique
  batchVersion              Int
  status                    PayrollOutputPackageStatus    @default(FINALIZED)
  finalizedAt               DateTime?
  finalizedById             String?
  reviewedById              String?
  reviewedAt                DateTime?
  approvedAt                DateTime?
  approvedById              String?
  employeeCount             Int                          @default(0)
  grossTotal                Decimal?                     @db.Decimal(14, 2)
  deductionTotal            Decimal?                     @db.Decimal(14, 2)
  netPayTotal               Decimal?                     @db.Decimal(14, 2)
  employerCostTotal         Decimal?                     @db.Decimal(14, 2)
  employeePensionTotal      Decimal?                     @db.Decimal(14, 2)
  employerPensionTotal      Decimal?                     @db.Decimal(14, 2)
  payeTaxTotal              Decimal?                     @db.Decimal(14, 2)
  snapshotHash              String?
  cancellationReason        String?
  cancelledById             String?
  cancelledAt               DateTime?
  createdAt                 DateTime                     @default(now())
  updatedAt                 DateTime                     @updatedAt

  payslipSnapshots  PayslipSnapshot[]
  paymentBatches    PayrollPaymentBatch[]
  exportRecords     PayrollExportRecord[]
  statutoryReports  PayrollStatutoryReport[]
  journalBatches    PayrollJournalBatch[]

  @@index([payrollPeriodId])
  @@index([payrollPreparationBatchId])
  @@index([status])
}

model PayslipSnapshot {
  id                        String   @id @default(uuid())
  outputPackageId           String
  payrollPeriodId           String
  payrollPreparationBatchId String
  payrollPreparationRowId   String
  employeeId                String
  employeeCode              String
  fullName                  String
  snapshotJson              String
  grossSalary               Decimal? @db.Decimal(14, 2)
  totalDeductions           Decimal? @db.Decimal(14, 2)
  netSalary                 Decimal? @db.Decimal(14, 2)
  documentHash              String?
  generatedAt               DateTime @default(now())
  publishedAt               DateTime?
  version                   Int      @default(1)

  outputPackage PayrollOutputPackage @relation(fields: [outputPackageId], references: [id])

  @@unique([outputPackageId, payrollPreparationRowId])
  @@index([employeeId])
  @@index([outputPackageId])
}

model PayrollPaymentBatch {
  id                 String                      @id @default(uuid())
  outputPackageId    String
  paymentMethod      PaymentMethod
  status             PayrollPaymentBatchStatus   @default(DRAFT)
  batchReference     String?
  currency           String                      @default("ETB")
  employeeCount      Int                         @default(0)
  totalAmount        Decimal?                    @db.Decimal(14, 2)
  generatedById      String?
  reviewedById       String?
  approvedById       String?
  releasedById       String?
  generatedAt        DateTime?
  reviewedAt         DateTime?
  approvedAt         DateTime?
  releasedAt         DateTime?
  cancelledAt        DateTime?
  cancellationReason String?

  outputPackage PayrollOutputPackage @relation(fields: [outputPackageId], references: [id])

  instructions PayrollPaymentInstruction[]

  @@index([outputPackageId])
  @@index([status])
}

model PayrollPaymentInstruction {
  id                 String                            @id @default(uuid())
  paymentBatchId     String
  employeeId         String
  payrollPreparationRowId String?
  paymentMethod      PaymentMethod
  beneficiaryName    String?
  bankName           String?
  bankAccountNumber  String?
  mpesaAccount       String?
  amount             Decimal?                          @db.Decimal(14, 2)
  status             PayrollPaymentInstructionStatus   @default(PENDING)
  externalReference  String?
  failureReason      String?
  paidAt             DateTime?
  snapshotJson       String?

  paymentBatch PayrollPaymentBatch @relation(fields: [paymentBatchId], references: [id])

  @@unique([paymentBatchId, employeeId])
  @@index([status])
  @@index([externalReference])
}

model PayrollExportRecord {
  id               String       @id @default(uuid())
  outputPackageId  String
  paymentBatchId   String?
  exportType       String
  format           ExportFormat
  fileName         String
  rowCount         Int          @default(0)
  totalAmount      Decimal?     @db.Decimal(14, 2)
  checksum         String?
  generatedById    String?
  generatedAt      DateTime     @default(now())
  downloadedCount  Int          @default(0)
  lastDownloadedAt DateTime?

  outputPackage PayrollOutputPackage @relation(fields: [outputPackageId], references: [id])

  @@index([outputPackageId])
  @@index([paymentBatchId])
}

model PayrollStatutoryReport {
  id               String                        @id @default(uuid())
  outputPackageId  String
  reportType       PayrollStatutoryReportType
  status           PayrollStatutoryReportStatus  @default(DRAFT)
  periodStart      DateTime?
  periodEnd        DateTime?
  employeeCount    Int                           @default(0)
  employeeAmount   Decimal?                      @db.Decimal(14, 2)
  employerAmount   Decimal?                      @db.Decimal(14, 2)
  totalAmount      Decimal?                      @db.Decimal(14, 2)
  reportHash       String?
  generatedById    String?
  reviewedById     String?
  approvedById     String?
  filedById        String?
  filingReference  String?
  filingDate       DateTime?
  generatedAt      DateTime                      @default(now())
  reviewedAt       DateTime?
  approvedAt       DateTime?
  filedAt          DateTime?

  outputPackage PayrollOutputPackage @relation(fields: [outputPackageId], references: [id])

  @@unique([outputPackageId, reportType])
  @@index([reportType])
}

model PayrollJournalBatch {
  id               String   @id @default(uuid())
  outputPackageId  String
  status           String   @default("DRAFT")
  totalDebit       Decimal? @db.Decimal(16, 2)
  totalCredit      Decimal? @db.Decimal(16, 2)
  generatedById    String?
  approvedById     String?
  generatedAt      DateTime @default(now())
  approvedAt       DateTime?

  outputPackage PayrollOutputPackage @relation(fields: [outputPackageId], references: [id])
