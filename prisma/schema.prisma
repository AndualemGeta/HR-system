  errorMessage  String?
  metadata      Json?
  createdAt     DateTime     @default(now())
  rows          ImportRow[]
  uploadedBy    User?        @relation(fields: [uploadedById], references: [id])
}

model ImportRow {
  id                String          @id @default(uuid())
  sessionId         String
  rowNumber         Int
  status            ImportRowStatus @default(PENDING)
  errors            String          @default("[]")
  warnings          String          @default("[]")
