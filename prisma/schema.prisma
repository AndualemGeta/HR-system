generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  COMMISSION_BASED
  CONTRACT
  INTERN
  TEMPORARY
  OTHER
}

enum EmploymentStatus {
  DRAFT
  ONBOARDING
  ACTIVE
  ON_PROBATION
  SUSPENDED
  ON_LEAVE
  TRANSFERRED
  RESIGNED
  TERMINATED
  EXITED
}

enum EmployeeRole {
  CEO
  CEO_COORDINATOR
  SALES_HEAD
  AREA_SALES_MANAGER
  SHOP_MANAGER
  SHOP_ACCOUNTANT
  DSA
  DSP
  BA_COORDINATOR
  CLEANING_STAFF
  SECURITY_STAFF
  EBU_SUPERVISOR
  EBU_FTTH_SUPERVISOR
  EBU_TECHNICAL_SALES_LEAD
  EBU_FTTH_SALES
  DISTRIBUTION_MANAGER
  DISTRIBUTION_OFFICER
  FINANCE_DIRECTOR
  TREASURY_MANAGER
  ACCOUNTANT
  FINANCIAL_CONTROL_REPORTING_MANAGER
  HR_MANAGER
  HR_OFFICER
  TECHNOLOGY_MANAGER
  EMPLOYEE
  OTHER
}

enum EmployeeLevel {
  JUNIOR
  MID
  SENIOR
  LEAD
  MANAGER
  DIRECTOR
  EXECUTIVE
  TO_BE_DEFINED
}

enum LocationType {
  DIVISION
  REGION
  SHOP
  CLUSTER
}

enum DocumentType {
  ID
  CONTRACT
  CV
  CERTIFICATE
  EMERGENCY_CONTACT
  BANK_OR_PAYMENT_INFORMATION
  TAX_OR_PAYROLL_INFORMATION
  COMMISSION_AGREEMENT
  ASSIGNMENT_LETTER
  RESPONSIBILITY_DOCUMENT
  CONFIDENTIALITY_DOCUMENT
  WARNING_LETTER
  TERMINATION_LETTER
  RESIGNATION_LETTER
  CLEARANCE
  EVALUATION_DOCUMENT
  SALARY_DOCUMENT
  OTHER
}

enum DocumentVisibility {
  PUBLIC_TO_HR
  MANAGER_VISIBLE
  EMPLOYEE_VISIBLE
  SENSITIVE_HR_ONLY
  SALARY_RESTRICTED
}

enum LeaveType {
  ANNUAL
  SICK
  MATERNITY
  PATERNITY
  UNPAID
  EMERGENCY
  COMPASSIONATE
  OTHER
}

enum EvaluationType {
  PROBATION
  MONTHLY
  QUARTERLY
  ANNUAL
  SHOP_MANAGER
  DISCIPLINARY_FOLLOW_UP
  PROMOTION_READINESS
  COMMISSION_REVIEW
  SALARY_REVIEW
  OTHER
}

enum EvaluationStatus {
  DRAFT
  SUBMITTED
  REVIEWED
  APPROVED
  REJECTED
}

enum ApprovalStatus {
  DRAFT
  SUBMITTED
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum DisciplinaryStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  ESCALATED
  CLOSED
}

enum TerminationStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  EXIT_IN_PROGRESS
  EXIT_COMPLETED
  CANCELLED
}

enum SalaryReviewStatus {
  DRAFT
  SUBMITTED
  HR_REVIEW
  FINANCE_REVIEW
  APPROVED
  REJECTED
  CANCELLED
  COMPLETED
}

enum PayrollBatchStatus {
  DRAFT
  VALIDATED
  APPROVED
  EXPORTED
  CANCELLED
}

enum PayrollReadiness {
  READY
  WARNING
  BLOCKED
}

enum PayrollLockStatus {
  UNLOCKED
  LOCKED
  UNLOCK_REQUESTED
}

enum CommissionCalculationType {
  FIXED_AMOUNT
  PERCENT_OF_SALES
  TIERED_PERCENT
  TARGET_BASED
  MANUAL
}

enum CommissionCalculationStatus {
  DRAFT
  CALCULATED
  UNDER_REVIEW
  APPROVED
  REJECTED
}

enum AllowanceType {
  KPI_ALLOWANCE
  TRANSPORT_ALLOWANCE
  HOUSING_ALLOWANCE
  POSITION_ALLOWANCE
  MEAL_ALLOWANCE
  COMMUNICATION_ALLOWANCE
  OTHER_ALLOWANCE
}

enum DeductionType {
  LOAN_DEDUCTION
  ADVANCE_DEDUCTION
  ABSENCE_DEDUCTION
  DAMAGE_DEDUCTION
  PENALTY_DEDUCTION
  OTHER_DEDUCTION
}

enum NotificationType {
  APPROVAL_REQUIRED
  APPROVAL_COMPLETED
  REQUEST_REJECTED
  CHANGES_REQUESTED
  DOCUMENT_UPLOADED
  REMINDER
  SYSTEM
}

enum AuditAction {
  LOGIN
  LOGOUT
  FAILED_LOGIN
  EMPLOYEE_CREATE
  EMPLOYEE_UPDATE
  EMPLOYEE_STATUS_CHANGE
  SALARY_CHANGE
  ASSIGNMENT_CHANGE
  DOCUMENT_UPLOAD
  DOCUMENT_VIEW
  DOCUMENT_DEACTIVATE
  LEAVE_CREATE
  LEAVE_APPROVAL
  LEAVE_REJECTION
  EVALUATION_CREATE
  EVALUATION_SUBMIT
  EVALUATION_APPROVAL
  EVALUATION_REJECTION
  DISCIPLINARY_CREATE
  DISCIPLINARY_APPROVAL
  TERMINATION_CREATE
  TERMINATION_APPROVAL
  TERMINATION_COMPLETE_EXIT
  TRANSFER_CREATE
  TRANSFER_APPROVAL
  TRANSFER_COMPLETE
  PROMOTION_CREATE
  PROMOTION_APPROVAL
  PROMOTION_COMPLETE
  SALARY_REVIEW_CREATE
  SALARY_REVIEW_APPROVAL
  SALARY_REVIEW_COMPLETE
  COMMISSION_CREATE
  COMMISSION_APPROVAL
  PAYROLL_BATCH_CREATE
  PAYROLL_BATCH_APPROVE
  PAYROLL_BATCH_EXPORT
  PAYROLL_PERIOD_LOCK
  PAYROLL_ADJUSTMENT
  IMPORT_UPLOAD
  IMPORT_APPROVE
  EXPORT_CREATE
  USER_CREATE
  USER_PERMISSION_CHANGE
  SYSTEM_SETTING_UPDATE
  PROFILE_CHANGE_REQUEST
  PROFILE_CHANGE_APPROVAL
  DATA_QUALITY_RESOLVE
  OTHER
}

model User {
  id                     String        @id @default(uuid())
  email                  String        @unique
  name                   String
  passwordHash           String
  isActive               Boolean       @default(true)
  passwordChangeRequired Boolean       @default(false)
  failedLoginCount       Int           @default(0)
  lockedUntil            DateTime?
  lastLoginAt            DateTime?
  employeeId             String?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt
  roles                  UserRole[]
  auditLogs              AuditLog[]
  notifications          Notification[]
}

model Role {
  id          String           @id @default(uuid())
  name        String           @unique
  description String?
  users       UserRole[]
  permissions RolePermission[]
}

model Permission {
  id          String           @id @default(uuid())
  key         String           @unique
  description String?
  roles       RolePermission[]
}

model UserRole {
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  @@id([userId, roleId])
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  @@id([roleId, permissionId])
}

model AuditLog {
  id         String     @id @default(uuid())
  userId     String?
  action     AuditAction
  entityType String
  entityId   String?
  oldValue   Json?
  newValue   Json?
  ipAddress  String?
  createdAt  DateTime   @default(now())
  user       User?      @relation(fields: [userId], references: [id])
  @@index([action, createdAt])
  @@index([entityType, entityId])
}

model Department {
  id        String       @id @default(uuid())
  name      String
  code      String       @unique(map: "dept_code_unique")
  parentId  String?
  headId    String?
  isActive  Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  parent    Department?  @relation("DepartmentTree", fields: [parentId], references: [id])
  children  Department[] @relation("DepartmentTree")
  head      Employee?    @relation("DepartmentHead", fields: [headId], references: [id])
  @@index([parentId])
}

model Location {
  id        String       @id @default(uuid())
  name      String
  code      String       @unique(map: "loc_code_unique")
  type      LocationType
  parentId  String?
  managerId String?
  isActive  Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  parent    Location?    @relation("LocationTree", fields: [parentId], references: [id])
  children  Location[]   @relation("LocationTree")
  manager   Employee?    @relation("LocationManager", fields: [managerId], references: [id])
  @@index([type])
  @@index([parentId])
}

model Employee {
  id                  String           @id @default(uuid())
  employeeId          String           @unique(map: "emp_employee_id_unique")
  firstName           String
  middleName          String?
  lastName            String
  fullName            String
  gender              String           @default("NOT_SPECIFIED")
  dateOfBirth         DateTime?
  phoneNumber         String?
  email               String?          @unique(map: "emp_email_unique")
  address             String?
  hireDate            DateTime?
  employmentType      EmploymentType?
  employmentStatus    EmploymentStatus @default(DRAFT)
  probationStatus     String           @default("NOT_APPLICABLE")
  currentDepartmentId String?
  currentDivisionId   String?
  currentRegionId     String?
  currentShopId       String?
  currentClusterId    String?
  currentRole         EmployeeRole     @default(OTHER)
  currentLevel        EmployeeLevel    @default(TO_BE_DEFINED)
  directManagerId     String?
  basicSalary         Decimal?         @db.Decimal(12, 2)
  salaryEffectiveDate DateTime?
  createdById         String?
  updatedById         String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  directManager       Employee?        @relation("EmployeeManager", fields: [directManagerId], references: [id])
  directReports       Employee[]       @relation("EmployeeManager")
  departmentsLed      Department[]     @relation("DepartmentHead")
  locationsManaged    Location[]       @relation("LocationManager")
  assignments         EmployeeAssignment[]
  statusHistory       EmployeeStatusHistory[]
  onboardingChecklist OnboardingChecklist?
  documents           EmployeeDocument[]
  leaveRecords        LeaveRecord[]
  salaries            EmployeeSalary[]
  salaryReviews       SalaryReview[]
  achievements        Achievement[]
  disciplinaryRecords DisciplinaryRecord[]
  terminations        TerminationCase[]
  transferRequests    TransferRequest[]
  promotionRequests   PromotionRequest[]
  commissionCalculations CommissionCalculation[]
  payrollRows         PayrollPreparationRow[]
  payrollAttendance   PayrollAttendanceInput[]
  payrollAllowances   PayrollAllowance[]
  payrollDeductions   PayrollDeduction[]
  evaluations         EmployeeEvaluation[]   @relation("EvaluationEmployee")
  evaluationsGiven    EmployeeEvaluation[]   @relation("EvaluationEvaluator")
  profileChangeRequests EmployeeProfileChangeRequest[]
  @@index([employmentStatus])
  @@index([currentRole])
  @@index([currentDepartmentId])
  @@index([directManagerId])
}

model EmployeeAssignment {
  id              String        @id @default(uuid())
  employeeId      String
  divisionId      String?
  departmentId    String?
  regionId        String?
  shopId          String?
  clusterId       String?
  role            EmployeeRole
  level           EmployeeLevel @default(TO_BE_DEFINED)
  directManagerId String?
  startDate       DateTime
  endDate         DateTime?
  reason          String?
  approvedById    String?
  createdAt       DateTime      @default(now())
  employee        Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  @@index([employeeId, endDate])
}

model EmployeeStatusHistory {
  id             String            @id @default(uuid())
  employeeId     String
  previousStatus EmploymentStatus?
  newStatus      EmploymentStatus
  reason         String
  effectiveDate  DateTime
  updatedById    String?
  createdAt      DateTime          @default(now())
  employee       Employee          @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  @@index([employeeId, effectiveDate])
}

model OnboardingChecklist {
  id          String                    @id @default(uuid())
  employeeId  String                    @unique
  status      ApprovalStatus            @default(DRAFT)
  completedAt DateTime?
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt
  employee    Employee                  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  items       OnboardingChecklistItem[]
}

model OnboardingChecklistItem {
  id            String              @id @default(uuid())
  checklistId   String
  key           String
  label         String
  completed     Boolean             @default(false)
  completedById String?
  completedAt   DateTime?
  checklist     OnboardingChecklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  @@unique([checklistId, key])
}

model EmployeeDocument {
  id               String             @id @default(uuid())
  employeeId       String
  documentType     DocumentType
  filePath         String
  originalFilename String?
  uploadedById     String?
  uploadedAt       DateTime           @default(now())
  visibilityLevel  DocumentVisibility @default(PUBLIC_TO_HR)
  notes            String?
  isActive         Boolean            @default(true)
  updatedAt        DateTime           @updatedAt
  employee         Employee           @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  @@index([employeeId, documentType])
  @@index([visibilityLevel, isActive])
}

model RequiredDocumentRule {
  id                       String          @id @default(uuid())
  name                     String
  documentType             DocumentType
  applicableEmploymentType EmploymentType?
  applicableRole           EmployeeRole?
  applicableDepartmentId   String?
  applicableDivisionId     String?
  isRequired               Boolean         @default(true)
  isActive                 Boolean         @default(true)
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt
}

model LeaveRecord {
  id             String         @id @default(uuid())
  employeeId     String
  leaveType      LeaveType
  startDate      DateTime
  endDate        DateTime
  totalDays      Decimal?       @db.Decimal(6, 2)
  reason         String?
  approvalStatus ApprovalStatus @default(PENDING)
  requestedById  String?
  approvedById   String?
  approvedAt     DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  employee       Employee       @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  @@index([employeeId, startDate])
}

model LeavePolicy {
  id                    String       @id @default(uuid())
  name                  String
  leaveType             LeaveType
  employmentType        EmploymentType?
  annualEntitlementDays Decimal      @db.Decimal(8, 2)
  carryForwardAllowed   Boolean      @default(false)
  maxCarryForwardDays   Decimal?     @db.Decimal(8, 2)
  isActive              Boolean      @default(true)
  effectiveStartDate    DateTime
  effectiveEndDate      DateTime?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
}

model LeaveBalance {
  id             String    @id @default(uuid())
  employeeId     String
  leaveType      LeaveType
  periodStart    DateTime
  periodEnd      DateTime
  openingBalance Decimal   @default(0) @db.Decimal(8, 2)
  accruedDays    Decimal   @default(0) @db.Decimal(8, 2)
  usedDays       Decimal   @default(0) @db.Decimal(8, 2)
  adjustedDays   Decimal   @default(0) @db.Decimal(8, 2)
  closingBalance Decimal   @default(0) @db.Decimal(8, 2)
  updatedAt      DateTime  @updatedAt
  @@unique([employeeId, leaveType, periodStart, periodEnd])
}

model LeaveBalanceAdjustment {
  id              String         @id @default(uuid())
  employeeId      String
  leaveType       LeaveType
  adjustmentDays  Decimal        @db.Decimal(8, 2)
  reason          String
  requestedById   String?
  approvedById    String?
  approvalStatus  ApprovalStatus @default(SUBMITTED)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model EmployeeEvaluation {
  id                         String           @id @default(uuid())
  employeeId                 String
  evaluatorId                String
  evaluationPeriodStart      DateTime
  evaluationPeriodEnd        DateTime
  evaluationType             EvaluationType
  score                      Decimal?         @db.Decimal(5, 2)
  rating                     String?
  comments                   String?
  strengths                  String?
  improvementAreas           String?
  status                     EvaluationStatus @default(DRAFT)
  submittedDate              DateTime?
  attachmentPath             String?
  compensationRecommendation String           @default("NO_CHANGE")
  salaryReviewRequired       Boolean          @default(false)
  commissionReviewRequired   Boolean          @default(false)
  createdAt                  DateTime         @default(now())
  updatedAt                  DateTime         @updatedAt
  employee                   Employee         @relation("EvaluationEmployee", fields: [employeeId], references: [id], onDelete: Cascade)
  evaluator                  Employee         @relation("EvaluationEvaluator", fields: [evaluatorId], references: [id])
  @@index([employeeId, status])
  @@index([evaluatorId])
}

model Achievement {
  id              String         @id @default(uuid())
  employeeId      String
  title           String
  description     String?
  achievementDate DateTime
  createdById     String?
  approvedById    String?
  approvalStatus  ApprovalStatus @default(PENDING)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  employee        Employee       @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  @@index([employeeId, approvalStatus])
}

model DisciplinaryRecord {
  id             String             @id @default(uuid())
  employeeId     String
  incidentType   String
  description    String
  actionTaken    String?
  warningLevel   String?
  incidentDate   DateTime
  issuedById     String?
  reviewedById   String?
  approvedById   String?
  attachmentPath String?
  followUpDate   DateTime?
  status         DisciplinaryStatus @default(DRAFT)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  employee       Employee           @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  @@index([employeeId, status])
}

model TerminationCase {
  id                  String            @id @default(uuid())
  employeeId          String
  terminationType     String
  reason              String
  noticeDate          DateTime?
  lastWorkingDate     DateTime?
  initiatedById       String?
  reviewedById        String?
  approvedById        String?
  status              TerminationStatus @default(DRAFT)
  finalPaymentStatus  String            @default("NOT_STARTED")
  clearanceStatus     String            @default("NOT_STARTED")
  exitInterviewStatus String            @default("NOT_STARTED")
  notes               String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  employee            Employee          @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  @@index([employeeId, status])
}

model TransferRequest {
  id                      String                @id @default(uuid())
  employeeId              String
  currentAssignmentId     String?
  requestedDivisionId     String?
  requestedDepartmentId   String?
  requestedRegionId       String?
  requestedShopId         String?
  requestedClusterId      String?
  requestedRole           EmployeeRole?
  requestedLevel          EmployeeLevel?
  reason                  String
  effectiveDate           DateTime?
  initiatedById           String?
  reviewedById            String?
  approvedById            String?
  status                  String                @default("DRAFT")
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  employee                Employee              @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  @@index([employeeId, status])
}

model PromotionRequest {
  id                     String                 @id @default(uuid())
  employeeId             String
  currentRole            EmployeeRole
  currentLevel           EmployeeLevel
  proposedRole           EmployeeRole?
  proposedLevel          EmployeeLevel?
  proposedSalary         Decimal?               @db.Decimal(12, 2)
  reason                 String
  effectiveDate          DateTime?
  initiatedById          String?
  reviewedById           String?
  approvedById           String?
  status                 String                 @default("DRAFT")
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  employee               Employee               @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  @@index([employeeId, status])
}

model ApprovalWorkflow {
  id           String           @id @default(uuid())
  name         String
  workflowType String
  isActive     Boolean          @default(true)
  createdById  String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  steps        ApprovalStep[]
  requests     ApprovalRequest[]
}

model ApprovalStep {
  id                  String           @id @default(uuid())
  workflowId          String
  stepOrder           Int
  approverRole        String?
  approverUserId      String?
  isRequired          Boolean          @default(true)
  preventSelfApproval Boolean          @default(true)
  escalationAfterDays Int?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  workflow            ApprovalWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  actions             ApprovalAction[]
  @@unique([workflowId, stepOrder])
}

model ApprovalRequest {
  id            String            @id @default(uuid())
  workflowId    String
  entityType    String
  entityId      String
  requestedById String?
  currentStep   Int               @default(1)
  status        String            @default("SUBMITTED")
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  workflow      ApprovalWorkflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  actions       ApprovalAction[]
  @@index([entityType, entityId])
}

model ApprovalAction {
  id                String          @id @default(uuid())
  approvalRequestId String
  stepId            String?
  actionById        String?
  action            String
  comments          String?
  createdAt         DateTime        @default(now())
  approvalRequest   ApprovalRequest @relation(fields: [approvalRequestId], references: [id], onDelete: Cascade)
  step              ApprovalStep?   @relation(fields: [stepId], references: [id])
}

model Notification {
  id                String           @id @default(uuid())
  recipientUserId   String
  title             String
  message           String
  notificationType  NotificationType
  relatedEntityType String?
  relatedEntityId   String?
  isRead            Boolean          @default(false)
  readAt            DateTime?
  createdAt         DateTime         @default(now())
  recipientUser     User             @relation(fields: [recipientUserId], references: [id], onDelete: Cascade)
  @@index([recipientUserId, isRead])
}

model EmployeeSalary {
  id            String   @id @default(uuid())
  employeeId    String
  basicSalary   Decimal  @db.Decimal(12, 2)
  effectiveDate DateTime
  reason        String
  approvedById  String?
  createdById   String?
  createdAt     DateTime @default(now())
  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  @@index([employeeId, effectiveDate])
}

model SalaryReview {
  id                  String             @id @default(uuid())
  employeeId          String
  currentSalary       Decimal?           @db.Decimal(12, 2)
  proposedSalary      Decimal            @db.Decimal(12, 2)
  changeAmount        Decimal            @default(0) @db.Decimal(12, 2)
  changePercent       Decimal            @default(0) @db.Decimal(8, 2)
  reason              String
  relatedEvaluationId String?
  effectiveDate       DateTime?
  requestedById       String?
  reviewedById        String?
  approvedById        String?
  status              SalaryReviewStatus @default(DRAFT)
  hrReviewStatus      String             @default("PENDING")
  financeReviewStatus String             @default("NOT_REQUIRED")
  notes               String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  employee            Employee           @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  @@index([employeeId, status])
}

model CommissionPlan {
  id                 String              @id @default(uuid())
  name               String
  description        String?
  applicableRole     EmployeeRole?
  calculationType    CommissionCalculationType
  rate               Decimal?            @db.Decimal(10, 4)
  fixedAmount        Decimal?            @db.Decimal(12, 2)
  capAmount          Decimal?            @db.Decimal(12, 2)
  isActive           Boolean             @default(true)
  effectiveStartDate DateTime
  effectiveEndDate   DateTime?
  createdById        String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  calculations       CommissionCalculation[]
}

model CommissionCalculation {
  id                     String                      @id @default(uuid())
  employeeId             String
  commissionPlanId       String?
  periodStart            DateTime
  periodEnd              DateTime
  salesAmount            Decimal?                    @db.Decimal(12, 2)
  targetAmount           Decimal?                    @db.Decimal(12, 2)
  achievementPercent     Decimal?                    @db.Decimal(8, 2)
  calculatedCommission   Decimal                     @default(0) @db.Decimal(12, 2)
  manualAdjustment       Decimal                     @default(0) @db.Decimal(12, 2)
  manualAdjustmentReason String?
  finalCommission        Decimal                     @default(0) @db.Decimal(12, 2)
  status                 CommissionCalculationStatus @default(DRAFT)
  calculatedById         String?
  reviewedById           String?
  approvedById           String?
  notes                  String?
  createdAt              DateTime                    @default(now())
  updatedAt              DateTime                    @updatedAt
  employee               Employee                    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  commissionPlan         CommissionPlan?             @relation(fields: [commissionPlanId], references: [id])
  @@index([employeeId, periodStart, periodEnd])
}

model PayrollRule {
  id                 String    @id @default(uuid())
  ruleType           String
  name               String
  description        String?
  rate               Decimal?  @db.Decimal(10, 4)
  amount             Decimal?  @db.Decimal(12, 2)
  effectiveStartDate DateTime
  effectiveEndDate   DateTime?
  isActive           Boolean   @default(true)
  approvalStatus     String    @default("DRAFT")
  changeReason       String?
  isSample           Boolean   @default(false)
  createdById        String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  @@index([ruleType, isActive])
}

model PayeTaxBracket {
  id                 String    @id @default(uuid())
  name               String
  minIncome          Decimal   @db.Decimal(12, 2)
  maxIncome          Decimal?  @db.Decimal(12, 2)
  taxRate            Decimal   @db.Decimal(10, 4)
  deductionAmount    Decimal   @default(0) @db.Decimal(12, 2)
  effectiveStartDate DateTime
  effectiveEndDate   DateTime?
  isActive           Boolean   @default(true)
  approvalStatus     String    @default("DRAFT")
  isSample           Boolean   @default(false)
  createdById        String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model PensionRule {
  id                       String          @id @default(uuid())
  name                     String
  employeeRate             Decimal         @db.Decimal(10, 4)
  employerRate             Decimal         @db.Decimal(10, 4)
  applicableEmploymentType EmploymentType?
  applicableRole           EmployeeRole?
  effectiveStartDate       DateTime
  effectiveEndDate         DateTime?
  isActive                 Boolean         @default(true)
  approvalStatus           String          @default("DRAFT")
  isSample                 Boolean         @default(false)
  createdById              String?
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt
}

model PayrollAttendanceInput {
  id                   String         @id @default(uuid())
  employeeId           String
  payrollPeriodStart   DateTime
  payrollPeriodEnd     DateTime
  workingDays          Decimal        @db.Decimal(8, 2)
  daysPresent          Decimal        @default(0) @db.Decimal(8, 2)
  daysAbsent           Decimal        @default(0) @db.Decimal(8, 2)
  paidLeaveDays        Decimal        @default(0) @db.Decimal(8, 2)
  unpaidLeaveDays      Decimal        @default(0) @db.Decimal(8, 2)
  sundayOvertimeHours  Decimal        @default(0) @db.Decimal(8, 2)
  holidayOvertimeHours Decimal        @default(0) @db.Decimal(8, 2)
  nightOvertimeHours   Decimal        @default(0) @db.Decimal(8, 2)
  approvalStatus       ApprovalStatus @default(DRAFT)
  approvedById         String?
  notes                String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  employee             Employee       @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  @@index([employeeId, payrollPeriodStart, payrollPeriodEnd])
}

model PayrollAllowance {
  id                 String         @id @default(uuid())
  employeeId         String
  payrollPeriodStart DateTime
  payrollPeriodEnd   DateTime
  allowanceType      AllowanceType
  amount             Decimal        @db.Decimal(12, 2)
  isTaxable          Boolean        @default(true)
  approvalStatus     ApprovalStatus @default(DRAFT)
  reason             String?
  createdById        String?
  approvedById       String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  employee           Employee       @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  @@index([employeeId, payrollPeriodStart, payrollPeriodEnd])
}

model PayrollDeduction {
  id                 String         @id @default(uuid())
  employeeId         String
  payrollPeriodStart DateTime
  payrollPeriodEnd   DateTime
  deductionType      DeductionType
  amount             Decimal        @db.Decimal(12, 2)
  isPreTax           Boolean        @default(false)
  approvalStatus     ApprovalStatus @default(DRAFT)
  reason             String?
  createdById        String?
  approvedById       String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  employee           Employee       @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  @@index([employeeId, payrollPeriodStart, payrollPeriodEnd])
}

model PayrollPreparationBatch {
  id                 String               @id @default(uuid())
  batchName          String
  payrollPeriodStart DateTime
  payrollPeriodEnd   DateTime
  status             PayrollBatchStatus   @default(DRAFT)
  totalEmployees     Int                  @default(0)
  readyCount         Int                  @default(0)
  blockedCount       Int                  @default(0)
  warningCount       Int                  @default(0)
  notes              String?
  createdById        String?
  approvedById       String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  rows               PayrollPreparationRow[]
  @@index([status])
}

model PayrollPreparationRow {
  id                   String                @id @default(uuid())
  batchId              String
  employeeId           String
  employeeCode         String
  fullName             String
  employmentType       String?
  division             String?
  department           String?
  region               String?
  shop                 String?
  role                 String
  level                String
  basicSalary          Decimal?              @db.Decimal(12, 2)
  workingDays          Decimal?              @db.Decimal(8, 2)
  daysPresent          Decimal?              @db.Decimal(8, 2)
  paidLeaveDays        Decimal?              @db.Decimal(8, 2)
  unpaidLeaveDays      Decimal?              @db.Decimal(8, 2)
  proratedBasicSalary  Decimal?              @db.Decimal(12, 2)
  approvedAllowances   Decimal?              @db.Decimal(12, 2)
  approvedCommission   Decimal?              @db.Decimal(12, 2)
  approvedDeductions   Decimal?              @db.Decimal(12, 2)
  overtimeAmount       Decimal?              @db.Decimal(12, 2)
  grossSalary          Decimal?              @db.Decimal(12, 2)
  employeePension      Decimal?              @db.Decimal(12, 2)
  employerPension      Decimal?              @db.Decimal(12, 2)
  taxableIncome        Decimal?              @db.Decimal(12, 2)
  payeTax              Decimal?              @db.Decimal(12, 2)
  netSalary            Decimal?              @db.Decimal(12, 2)
  employerTotalCost    Decimal?              @db.Decimal(12, 2)
  manualAdjustments    Decimal?              @db.Decimal(12, 2)
  readinessStatus      PayrollReadiness
  blockers             Json?
  warnings             Json?
  calculationBreakdown Json?
  includedInExport     Boolean               @default(true)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  batch                PayrollPreparationBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  employee             Employee              @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  @@unique([batchId, employeeId])
}

model PayrollPeriodLock {
