  department     String?
  region         String?
  shop           String?
  description    String?
  sourceType     String?
  sourceId       String?

  journalBatch PayrollJournalBatch @relation(fields: [journalBatchId], references: [id])

  @@index([journalBatchId])
}

model PaymentExportTemplate {
  id                String   @id @default(uuid())
  code              String   @unique
  name              String
  paymentMethod     PaymentMethod
  format            ExportFormat
  delimiter         String   @default(",")
  hasHeader         Boolean  @default(true)
  dateFormat        String   @default("YYYY-MM-DD")
  amountFormat      String   @default("0.00")
  encoding          String   @default("UTF-8")
  columnConfigJson  String
  isActive          Boolean  @default(true)
  version           Int      @default(1)
  createdById       String?
  approvedById      String?
  approvedAt        DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model GlAccountMapping {
  id          String @id @default(uuid())
  category    String @unique
  accountCode String
  accountName String?
  description String?
  isActive    Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PayrollPaymentRetryBatch {
  id                   String   @id @default(uuid())
  sourceInstructionId  String
  retryPaymentBatchId  String
  originalAmount       Decimal? @db.Decimal(14, 2)
  retryReason          String?
