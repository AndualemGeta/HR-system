  lockedAt            DateTime?
  unlockRequestedById String?
  unlockedById        String?
  unlockedAt          DateTime?
  reason              String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  @@unique([payrollPeriodStart, payrollPeriodEnd])
}

model PayrollAdjustment {
  id                 String         @id @default(uuid())
