model User {
  id                      String                   @id @default(uuid())
  email                   String                   @unique
  name                    String
  passwordHash            String
  status                  UserStatus               @default(ACTIVE)
  employeeId              String?
  employee                Employee?                @relation("UserEmployee", fields: [employeeId], references: [id])
  passwordChangeRequired  Boolean                  @default(false)
  failedLoginCount        Int                      @default(0)
  lockedUntil             DateTime?
  lastLoginAt             DateTime?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  roles                   UserRole[]
  auditLogs               AuditLog[]
  notifications           Notification[]           @relation("NotificationRecipient")
  notificationPreferences NotificationPreference[]
  createdEmployees        Employee[]               @relation("EmployeeCreatedBy")
  updatedEmployees        Employee[]               @relation("EmployeeUpdatedBy")

  @@index([status])
}

model Role {
  id          String           @id @default(uuid())
  name        SystemRole       @unique
  description String?
  users       UserRole[]
  permissions RolePermission[]
}

model Permission {
  id          String           @id @default(uuid())
  key         String           @unique
  description String?
  roles       RolePermission[]
}

model UserRole {
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model OrganizationUnit {
  id        String             @id @default(uuid())
  name      String
  code      String?            @unique
  type      OrgUnitType
  parentId  String?
  parent    OrganizationUnit?  @relation("OrgUnitTree", fields: [parentId], references: [id])
  children  OrganizationUnit[] @relation("OrgUnitTree")
  managerId String?
  manager   Employee?          @relation("OrgUnitManager", fields: [managerId], references: [id])
  active    Boolean            @default(true)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@index([parentId])
  @@index([type])
}

model Department {
  id                   String                @id @default(uuid())
  name                 String
  code                 String                @unique
  parentId             String?
  parent               Department?           @relation("DepartmentTree", fields: [parentId], references: [id])
  children             Department[]          @relation("DepartmentTree")
  headId               String?
  head                 Employee?             @relation("DepartmentHead", fields: [headId], references: [id])
  active               Boolean               @default(true)
  employees            Employee[]            @relation("EmployeeDepartment")
  assignments          EmployeeAssignment[]
  evaluationCriteria   EvaluationCriteria[]
  evaluationScoreItems EvaluationScoreItem[]
  achievements         Achievement[]
  requiredDocumentRules RequiredDocumentRule[]
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  @@index([parentId])
}

model Location {
  id                   String               @id @default(uuid())
  name                 String
  code                 String               @unique
  type                 LocationType
  parentId             String?
  parent               Location?            @relation("LocationTree", fields: [parentId], references: [id])
  children             Location[]           @relation("LocationTree")
  managerId            String?
  manager              Employee?            @relation("LocationManager", fields: [managerId], references: [id])
  active               Boolean              @default(true)
  employeesDivision    Employee[]           @relation("EmployeeDivision")
  employeesRegion      Employee[]           @relation("EmployeeRegion")
  employeesShop        Employee[]           @relation("EmployeeShop")
  employeesCluster     Employee[]           @relation("EmployeeCluster")
  assignmentDivision   EmployeeAssignment[] @relation("AssignmentDivision")
  assignmentRegion     EmployeeAssignment[] @relation("AssignmentRegion")
  assignmentShop       EmployeeAssignment[] @relation("AssignmentShop")
  assignmentCluster    EmployeeAssignment[] @relation("AssignmentCluster")
  achievementsDivision Achievement[]        @relation("AchievementDivision")
  achievementsRegion   Achievement[]        @relation("AchievementRegion")
  achievementsShop     Achievement[]        @relation("AchievementShop")
  requiredDocumentRules RequiredDocumentRule[]
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  @@index([type])
  @@index([parentId])
}

model Employee {
  id                      String                         @id @default(uuid())
  employeeId              String                         @unique
  firstName               String
  middleName              String?
  lastName                String
  fullName                String
  gender                  Gender                         @default(NOT_SPECIFIED)
  dateOfBirth             DateTime?
  phoneNumber             String?
  email                   String?                        @unique
  address                 String?
  hireDate                DateTime?
  employmentType          EmploymentType?
  employmentStatus        EmploymentStatus               @default(DRAFT)
  probationStatus         ProbationStatus                @default(NOT_APPLICABLE)
  currentDepartmentId     String?
