  CANCELLED
}

enum MvpPayrollRowValidationStatus {
  PENDING
  VALID
  WARNING
  ERROR
}

model MvpPayrollPeriod {
  id          String                  @id @default(uuid())
  month       Int
  year        Int
  periodName  String
  periodStart DateTime
  periodEnd   DateTime
  payDate     DateTime
  status      MvpPayrollPeriodStatus  @default(DRAFT)
  readyById   String?
  readyAt     DateTime?
  lockedById  String?
  lockedAt    DateTime?
  reopenReason String?
  reopenedById String?
  reopenedAt  DateTime?
  createdById String?
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  rows        MvpPayrollRow[]
  exports     MvpPayrollExport[]

  @@unique([month, year])
  @@index([status])
}

model MvpPayrollRow {
  id                  String                       @id @default(uuid())
  payrollPeriodId     String
  employeeId          String
  employeeCode        String
  employeeName        String
  department          String?
  role                String?
  location            String?
  basicSalary         Decimal?                     @db.Decimal(12, 2)
  workingDays         Decimal?                     @db.Decimal(6, 2)
  monthlySalary       Decimal?                     @db.Decimal(12, 2)
  allowance           Decimal?                     @db.Decimal(12, 2)
  overtime            Decimal?                     @db.Decimal(12, 2)
  incentive           Decimal?                     @db.Decimal(12, 2)
  commission          Decimal?                     @db.Decimal(12, 2)
  grossSalary         Decimal?                     @db.Decimal(12, 2)
  taxableIncome       Decimal?                     @db.Decimal(12, 2)
  employeePension     Decimal?                     @db.Decimal(12, 2)
  employerPension     Decimal?                     @db.Decimal(12, 2)
  incomeTax           Decimal?                     @db.Decimal(12, 2)
  otherDeduction      Decimal?                     @db.Decimal(12, 2)
  totalDeduction      Decimal?                     @db.Decimal(12, 2)
  netSalary           Decimal?                     @db.Decimal(12, 2)
  paymentMethod       String?
  bankName            String?
  bankAccountNumber   String?
  mpesaAccount        String?
  notes               String?
  hireDate            DateTime?
  pensionEligible     Boolean?
  validationStatus    MvpPayrollRowValidationStatus @default(PENDING)
  validationMessages  Json?
  snapshotJson        Json?
  overrideReason      String?
  createdAt           DateTime                     @default(now())
  updatedAt           DateTime                     @updatedAt
  payrollPeriod       MvpPayrollPeriod             @relation(fields: [payrollPeriodId], references: [id], onDelete: Cascade)
  employee            Employee                     @relation(fields: [employeeId], references: [id])

  @@unique([payrollPeriodId, employeeId])
  @@index([payrollPeriodId])
  @@index([employeeId])
}

model MvpPayrollExport {
  id              String   @id @default(uuid())
  payrollPeriodId String
  fileName        String
  format          String   @default("XLSX")
  rowCount        Int      @default(0)
  totalGross      Decimal? @db.Decimal(14, 2)
  totalDeductions Decimal? @db.Decimal(14, 2)
  totalNet        Decimal? @db.Decimal(14, 2)
  checksum        String?
  templateVersion String?
  generatedById   String?
  generatedAt     DateTime @default(now())
  downloadedCount Int      @default(0)
  payrollPeriod   MvpPayrollPeriod @relation(fields: [payrollPeriodId], references: [id])

  @@index([payrollPeriodId])
}
