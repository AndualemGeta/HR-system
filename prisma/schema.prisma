model User {
  id                            String                            @id @default(uuid())
  email                         String                            @unique
  name                          String
  passwordHash                  String
  isActive                      Boolean                           @default(true)
  passwordChangeRequired        Boolean                           @default(false)
  failedLoginCount              Int                               @default(0)
  lockedUntil                   DateTime?
  lastLoginAt                   DateTime?
  employeeId                    String?
  createdAt                     DateTime                          @default(now())
  updatedAt                     DateTime                          @updatedAt
  roles                         UserRole[]
  auditLogs                     AuditLog[]
  notifications                 Notification[]
  imports                       ImportSession[]
  payComponentsCreated          PayComponent[]                    @relation("PayComponentCreatedBy")
  payComponentsUpdated          PayComponent[]                    @relation("PayComponentUpdatedBy")
  payRulesCreated               PayRule[]                         @relation("PayRuleCreatedBy")
  payRulesUpdated               PayRule[]                         @relation("PayRuleUpdatedBy")
  payrollPeriodsCreated         PayrollPeriod[]
  inputTypesCreated             PayrollInputType[]                @relation("InputTypeCreatedBy")
  inputTypesUpdated             PayrollInputType[]                @relation("InputTypeUpdatedBy")
  payrollPeriodEmployeesAdded   PayrollPeriodEmployee[]           @relation("PPEmployeeAddedBy")
  payrollPeriodEmployeesRemoved PayrollPeriodEmployee[]           @relation("PPEmployeeRemovedBy")
  payrollInputsSubmitted        PayrollInput[]                    @relation("PayrollInputSubmittedBy")
  payrollInputsLocked           PayrollInput[]                    @relation("PayrollInputLockedBy")
  inputRequirementsCreated      PayrollInputRequirement[]         @relation("InputRequirementCreatedBy")
  inputRequirementsUpdated      PayrollInputRequirement[]         @relation("InputRequirementUpdatedBy")
  inputWaiversCreated           PayrollInputWaiver[]              @relation("InputWaiverCreatedBy")
  shopProfilesCreated           ShopProfile[]                     @relation("ShopProfileCreator")
  shopProfilesUpdated           ShopProfile[]                     @relation("ShopProfileUpdater")
  shopCriteriaUpdated           ShopCriteriaStatusHistory[]       @relation("ShopCriteriaUpdater")
  shopCriteriaApproved          ShopCriteriaStatusHistory[]       @relation("ShopCriteriaApprover")
  incentivePeriodsCreated       ShopManagerIncentivePeriod[]      @relation("IncentivePeriodCreatedBy")
  incentiveInputsCreated        ShopManagerIncentiveInput[]       @relation("IncentiveInputCreatedBy")
  incentiveInputsUpdated        ShopManagerIncentiveInput[]       @relation("IncentiveInputUpdatedBy")
}

model Role {
  id          String           @id @default(uuid())
  name        String           @unique
  description String?
  users       UserRole[]
  permissions RolePermission[]
}

model Permission {
  id          String           @id @default(uuid())
  key         String           @unique
  description String?
  roles       RolePermission[]
}

model UserRole {
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model AuditLog {
  id         String      @id @default(uuid())
  userId     String?
  action     AuditAction
  entityType String
  entityId   String?
  oldValue   Json?
  newValue   Json?
  ipAddress  String?
  createdAt  DateTime    @default(now())
  user       User?       @relation(fields: [userId], references: [id])

  @@index([action, createdAt])
  @@index([entityType, entityId])
}

model Department {
  id        String       @id @default(uuid())
  name      String
  code      String       @unique(map: "dept_code_unique")
  parentId  String?
  headId    String?
  isActive  Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  parent    Department?  @relation("DepartmentTree", fields: [parentId], references: [id])
  children  Department[] @relation("DepartmentTree")
  head      Employee?    @relation("DepartmentHead", fields: [headId], references: [id])

  @@index([parentId])
}

model Location {
  id                         String                            @id @default(uuid())
  name                       String
  code                       String                            @unique(map: "loc_code_unique")
  type                       LocationType
  parentId                   String?
  managerId                  String?
  isActive                   Boolean                           @default(true)
  createdAt                  DateTime                          @default(now())
  updatedAt                  DateTime                          @updatedAt
  parent                     Location?                         @relation("LocationTree", fields: [parentId], references: [id])
  children                   Location[]                        @relation("LocationTree")
  manager                    Employee?                         @relation("LocationManager", fields: [managerId], references: [id])
  shopProfile                ShopProfile?
  criteriaHistory            ShopCriteriaStatusHistory[]
  incentiveInputs      ShopManagerIncentiveInput[]
  incentiveCalculations ShopManagerIncentiveCalculation[]

  @@index([type])
  @@index([parentId])
}

model ShopProfile {
  id                   String       @id @default(uuid())
  shopLocationId       String       @unique(map: "shop_profile_location_unique")
  corridorType         CorridorType @default(UNKNOWN)
  defaultShopManagerId String?
  isIncentiveEligible  Boolean      @default(false)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  createdById          String?
  updatedById          String?
  shopLocation         Location     @relation(fields: [shopLocationId], references: [id])
  defaultShopManager   Employee?    @relation("ShopDefaultManager", fields: [defaultShopManagerId], references: [id])
  createdBy            User?        @relation("ShopProfileCreator", fields: [createdById], references: [id])
  updatedBy            User?        @relation("ShopProfileUpdater", fields: [updatedById], references: [id])
}

model ShopCriteriaStatusHistory {
  id             String       @id @default(uuid())
  shopLocationId String
  criteria       ShopCriteria @default(UNASSIGNED)
  effectiveFrom  DateTime
  effectiveTo    DateTime?
  reason         String?
  updatedById    String?
  approvedById   String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  shopLocation   Location     @relation(fields: [shopLocationId], references: [id])
  updatedBy      User?        @relation("ShopCriteriaUpdater", fields: [updatedById], references: [id])
  approvedBy     User?        @relation("ShopCriteriaApprover", fields: [approvedById], references: [id])

  @@index([shopLocationId, effectiveFrom])
  @@index([shopLocationId, effectiveTo])
}

model Employee {
  id                           String                            @id @default(uuid())
  employeeId                   String                            @unique(map: "emp_employee_id_unique")
  firstName                    String
  middleName                   String?
  lastName                     String?
  fullName                     String
  gender                       String                            @default("NOT_SPECIFIED")
  dateOfBirth                  DateTime?
  phoneNumber                  String?
  email                        String?                           @unique(map: "emp_email_unique")
  address                      String?
  hireDate                     DateTime?
  employmentType               EmploymentType?
  employmentStatus             EmploymentStatus                  @default(DRAFT)
  employeeCategory             EmployeeCategory?
  probationStatus              String                            @default("NOT_APPLICABLE")
  currentDepartmentId          String?
  currentDivisionId            String?
  currentRegionId              String?
  currentAreaId                String?
  currentShopId                String?
  currentClusterId             String?
  currentRole                  EmployeeRole                      @default(OTHER)
  currentLevel                 EmployeeLevel                     @default(TO_BE_DEFINED)
  directManagerId              String?
  accountingReportingManagerId String?
  basicSalary                  Decimal?                          @db.Decimal(12, 2)
  salaryEffectiveDate          DateTime?
  notes                        String?
  createdById                  String?
  updatedById                  String?
  createdAt                    DateTime                          @default(now())
  updatedAt                    DateTime                          @updatedAt
  directManager                Employee?                         @relation("EmployeeManager", fields: [directManagerId], references: [id])
  accountingReportingManager   Employee?                         @relation("AccountingManager", fields: [accountingReportingManagerId], references: [id])
  accountingReportees          Employee[]                        @relation("AccountingManager")
  directReports                Employee[]                        @relation("EmployeeManager")
  departmentsLed               Department[]                      @relation("DepartmentHead")
  locationsManaged             Location[]                        @relation("LocationManager")
  assignments                  EmployeeAssignment[]
  statusHistory                EmployeeStatusHistory[]
  onboardingChecklist          OnboardingChecklist?
  documents                    EmployeeDocument[]
  leaveRecords                 LeaveRecord[]
  salaries                     EmployeeSalary[]
  salaryReviews                SalaryReview[]
  achievements                 Achievement[]
  disciplinaryRecords          DisciplinaryRecord[]
  terminations                 TerminationCase[]
  transferRequests             TransferRequest[]
  promotionRequests            PromotionRequest[]
  commissionCalculations       CommissionCalculation[]
  payrollRows                  PayrollPreparationRow[]
  payrollCalculationLines      PayrollCalculationLine[]
  payrollAttendance            PayrollAttendanceInput[]
  payrollAllowances            PayrollAllowance[]
  payrollDeductions            PayrollDeduction[]
  evaluations                  EmployeeEvaluation[]              @relation("EvaluationEmployee")
  evaluationsGiven             EmployeeEvaluation[]              @relation("EvaluationEvaluator")
  profileChangeRequests        EmployeeProfileChangeRequest[]
  payrollProfile               EmployeePayrollProfile?
  payrollPeriodEmployees       PayrollPeriodEmployee[]
  payrollInputs                PayrollInput[]
  payrollInputWaivers          PayrollInputWaiver[]
  shopDefaultManagerProfiles   ShopProfile[]                     @relation("ShopDefaultManager")
  incentiveInputs      ShopManagerIncentiveInput[]     @relation("IncentiveInputManager")
  incentiveCalculations ShopManagerIncentiveCalculation[] @relation("IncentiveCalculationManager")
  payComponentAssignments EmployeePayComponentAssignment[]
  mvpPayrollRows          MvpPayrollRow[]

  @@index([employmentStatus])
  @@index([currentRole])
  @@index([currentDepartmentId])
  @@index([directManagerId])
  @@index([accountingReportingManagerId])
  @@index([employeeCategory])
}

model EmployeeAssignment {
  id                           String            @id @default(uuid())
  employeeId                   String
  employeeCategory             EmployeeCategory?
  departmentId                 String?
  divisionId                   String?
  regionId                     String?
  areaId                       String?
  shopId                       String?
  clusterId                    String?
  role                         EmployeeRole
  level                        EmployeeLevel     @default(TO_BE_DEFINED)
  directManagerId              String?
  accountingReportingManagerId String?
  isActive                     Boolean           @default(true)
  startDate                    DateTime
  endDate                      DateTime?
  reason                       String?
  approvedById                 String?
  createdAt                    DateTime          @default(now())
  employee                     Employee          @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId, endDate])
  @@index([employeeId, isActive])
}

model EmployeeStatusHistory {
  id             String            @id @default(uuid())
  employeeId     String
  previousStatus EmploymentStatus?
  newStatus      EmploymentStatus
  reason         String
  effectiveDate  DateTime
  updatedById    String?
  createdAt      DateTime          @default(now())
  employee       Employee          @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId, effectiveDate])
}

model OnboardingChecklist {
  id          String                    @id @default(uuid())
  employeeId  String                    @unique
  status      ApprovalStatus            @default(DRAFT)
  completedAt DateTime?
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt
  employee    Employee                  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  items       OnboardingChecklistItem[]
}

