# Database connection string (update user, password, host, port, and database name)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/leapfrog_hr?schema=public"

# Session encryption key — generate with: openssl rand -base64 32 (must be at least 32 characters)
AUTH_SECRET="change-this-to-at-least-32-random-characters"

# Application base URL (used for redirects and links in emails)
APP_URL="http://localhost:3000"

# Local directory for uploaded employee documents (replace with S3-compatible storage in production)
UPLOAD_DIR="./storage/uploads"

# Optional: Password policy (defaults shown)
# PASSWORD_MIN_LENGTH=10
# FAILED_LOGIN_LOCKOUT_THRESHOLD=5
# FAILED_LOGIN_LOCKOUT_MINUTES=15
