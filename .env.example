# Leapfrog HR Management System - Environment Configuration
# Copy this file to .env and update values for your environment.

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://user:password@localhost:5432/leapfrog_hr?schema=public"

# Secret key used to sign session JWTs
# Generate with: openssl rand -base64 32
# This is REQUIRED in production - the app will fail to start without it.
AUTH_SECRET="change-this-to-a-random-secret-at-least-32-chars"

# Application URL (used for redirects and links)
APP_URL="http://localhost:3000"

# Directory for file uploads (used by document storage)
UPLOAD_DIR="./storage/uploads"
