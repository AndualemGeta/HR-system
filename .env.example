# Leapfrog HR Management System - Environment Configuration
# Copy this file to .env and update values for your environment.

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/leapfrog_hr?schema=public"

# Secret key used to sign session JWTs
# Generate with: openssl rand -base64 32 (Linux/macOS)
# or: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))" (Windows)
# This is REQUIRED in production - the app will fail to start without it.
# Minimum 32 characters.
AUTH_SECRET="change-this-to-a-random-secret-at-least-32-chars"

# Application URL (used for redirects and links)
APP_URL="http://localhost:3000"

# Directory for file uploads (used by document storage)
UPLOAD_DIR="./storage/uploads"

# MVP Mode: hides Phase 5A/5B routes from the dashboard and middleware
# Set to "true" to enable MVP-only view
MVP_MODE=true

# Payroll export directory: stores generated payroll Excel files
# Must point to a persistent storage location in production
PAYROLL_EXPORT_DIR="./storage/payroll-exports"
